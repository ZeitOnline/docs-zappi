{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"dependencyDashboard": true,
	"commitMessagePrefix": "MAINT: ",
	"schedule": ["before 8am on wednesday"],
	"enabledManagers": ["github-actions", "npm", "pep621"],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": [
			"before 8am on wednesday"
		],
		"commitMessageAction": "Update dependencies"
	},
	"packageRules": [
		{
			"groupName": "All minor github-actions changes",
			"matchManagers": ["github-actions"],
			"matchUpdateTypes": ["minor", "patch"]
		},
		{
			"groupName": "All minor npm changes",
			"matchManagers": ["npm"],
			"matchUpdateTypes": ["minor", "patch"]
		},
		{
			"groupName": "All minor python changes",
			"matchManagers": ["pep621"],
			"matchUpdateTypes": ["minor", "patch"]
		}
	]
}
