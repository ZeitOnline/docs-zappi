#!/bin/bash

set -e

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

cd $DIR/..
if [[ uv.lock -nt .uv.success ]]; then
    uv sync
    touch .uv.success
fi

cd $DIR/../docs/api
if [[ package-lock.json -nt .npm.success ]]; then
    npm install
    touch .npm.success
fi

cd $DIR/..
bin/swagger-cli validate $DIR/../docs/api/api.yaml

.venv/bin/openapi-spec-validator $DIR/../docs/api/api.yaml
